# Copy to .env or .env.local only if you need overrides.
# Never paste real secrets into AI chat or commit them to git.

APP_ENV=local
DATABASE_URL=postgresql+asyncpg://app:app@127.0.0.1:5432/scaffold
AUTH_ALLOWED_EMAIL_DOMAINS=
SESSION_SECRET=change-me-local-only

# Development quick-login is local/test only.
DEV_PASSWORD_LOGIN_ENABLED=true
DEV_PASSWORD_LOGIN_USERNAME=admin
DEV_PASSWORD_LOGIN_PASSWORD=local-dev-password
DEV_PASSWORD_LOGIN_EMAIL=admin@example.com

# LLM settings. Run `make llm_local_setup` once to download the default 4.5 GB local Qwen model into the
# normal Hugging Face cache without using an API key.
LLM_PROVIDER=local_qwen
LLM_MODEL=Qwen/Qwen3.5-2B
LLM_LOCAL_BASE_URL=http://127.0.0.1:8002
LLM_LOCAL_TIMEOUT_SECONDS=600
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Optional scheduled endpoint protection.
SCHEDULER_SHARED_TOKEN=

# Optional bot protection for public apps.
BOT_PROTECTION_ENABLED=false
BOT_SECRET_KEY=
